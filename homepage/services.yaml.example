---
# Homepage Services Configuration
# Copy to your Homepage config directory and fill in API keys.

- Media Automation:
    - Radarr:
        icon: radarr.png
        href: http://{{HOMEPAGE_VAR_NAS_IP}}:7878
        description: Movie automation
        server: my-docker
        container: radarr
        widget:
          type: radarr
          url: http://radarr:7878
          key: {{HOMEPAGE_VAR_RADARR_KEY}}

    - Sonarr:
        icon: sonarr.png
        href: http://{{HOMEPAGE_VAR_NAS_IP}}:8989
        description: TV show automation
        server: my-docker
        container: sonarr
        widget:
          type: sonarr
          url: http://sonarr:8989
          key: {{HOMEPAGE_VAR_SONARR_KEY}}

    - Prowlarr:
        icon: prowlarr.png
        href: http://{{HOMEPAGE_VAR_NAS_IP}}:9696
        description: Indexer manager
        server: my-docker
        container: prowlarr
        widget:
          type: prowlarr
          url: http://prowlarr:9696
          key: {{HOMEPAGE_VAR_PROWLARR_KEY}}

    - Bazarr:
        icon: bazarr.png
        href: http://{{HOMEPAGE_VAR_NAS_IP}}:6767
        description: Subtitle automation
        server: my-docker
        container: bazarr
        widget:
          type: bazarr
          url: http://bazarr:6767
          key: {{HOMEPAGE_VAR_BAZARR_KEY}}

- Downloads:
    - SABnzbd:
        icon: sabnzbd.png
        href: http://{{HOMEPAGE_VAR_NAS_IP}}:8085
        description: Usenet downloader
        server: my-docker
        container: sabnzbd
        widget:
          type: sabnzbd
          url: http://sabnzbd:8080
          key: {{HOMEPAGE_VAR_SABNZBD_KEY}}

- Media:
    - Jellyfin:
        icon: jellyfin.png
        href: http://{{HOMEPAGE_VAR_NAS_IP}}:8899
        description: Media server
        server: my-docker
        container: jellyfin
        widget:
          type: jellyfin
          url: http://jellyfin:8096
          key: {{HOMEPAGE_VAR_JELLYFIN_KEY}}
          enableBlocks: true
          enableNowPlaying: true

    - Jellyseerr:
        icon: jellyseerr.png
        href: http://{{HOMEPAGE_VAR_NAS_IP}}:5055
        description: Request management
        server: my-docker
        container: jellyseerr
        widget:
          type: jellyseerr
          url: http://jellyseerr:5055
          key: {{HOMEPAGE_VAR_JELLYSEERR_KEY}}

- System:
    - Immich:
        icon: immich.png
        href: http://{{HOMEPAGE_VAR_NAS_IP}}:2283
        description: Photo management
        server: my-docker
        container: immich-server
        widget:
          type: immich
          url: http://immich-server:2283
          key: {{HOMEPAGE_VAR_IMMICH_KEY}}

    - AdGuard Home:
        icon: adguardhome.png
        href: http://{{HOMEPAGE_VAR_ADGUARD_IP}}:3000
        description: Network-wide ad blocking
        widget:
          type: adguard
          url: http://{{HOMEPAGE_VAR_ADGUARD_IP}}
          username: {{HOMEPAGE_VAR_ADGUARD_USER}}
          password: {{HOMEPAGE_VAR_ADGUARD_PASS}}
