# =============================================================================
# Homelab Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control!
# =============================================================================

# --- System ---
PUID=1000
PGID=10
TZ=Europe/Stockholm

# --- Paths (adjust for your NAS volume layout) ---
DOCKER_BASE_PATH=/volume2/docker
DOCKER_CONFIG_PATH=/volume2/docker/arr-stack
MEDIA_PATH=/volume1/Media/Media
DOWNLOADS_PATH=/volume1/Media/Torrents
USENET_PATH=/volume1/Media/usenet
PHOTOS_PATH=/volume1/Media/Photos
BACKUPS_PATH=/volume1/Media/Backups

# --- Network ---
NAS_IP=192.168.x.x
LAN_SUBNET=192.168.x.0/24
LAN_GATEWAY=192.168.x.1
ADGUARD_IP=192.168.x.200

# --- Arr Stack API Keys ---
SONARR_API_KEY=your-sonarr-api-key
RADARR_API_KEY=your-radarr-api-key

# --- Immich Database ---
IMMICH_DB_USER=postgres
IMMICH_DB_PASSWORD=change-me-strong-password
IMMICH_DB_NAME=immich

# --- Duplicati ---
DUPLICATI_WEB_PASSWORD=change-me-strong-password
DUPLICATI_ENCRYPTION_KEY=change-me-64-char-random-string

# --- Homepage ---
HOMEPAGE_PASSWORD=change-me-strong-password

# --- Paperless-ngx ---
PAPERLESS_DB_PASSWORD=change-me-strong-password
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=change-me-strong-password
PAPERLESS_TITLE=Paperless-ngx
